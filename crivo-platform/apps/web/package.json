{
  "name": "@crivo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "cap:build": "CAP_EXPORT=1 NODE_ENV=production next build",
    "cap:sync": "pnpm cap:build && npx cap sync android",
    "android:aab": "pnpm cap:sync && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8",
    "@capacitor/core": "^8",
    "@crivo/types": "workspace:*",
    "@crivo/ui": "workspace:*",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5.6.0"
  }
}
