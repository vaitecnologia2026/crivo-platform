# ── CRIVO API — variáveis de ambiente ──
# Copie para .env (local) ou configure no painel do Railway (produção).
# NUNCA commitar o .env real. Ver crivo-platform/docs/DEPLOY-BACKEND.md.

# Conexão OWNER (postgres) — migrations, provisionamento e control plane.
# No Railway pode referenciar: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:SENHA@HOST:PORTA/railway"

# Conexão de APLICAÇÃO (crivo_app) — RLS por tenant. MESMO host/porta/banco,
# usuário crivo_app (criado pelo rls.sql). O boot FALHA sem esta variável.
DATABASE_URL_APP="postgresql://crivo_app:SENHA_FORTE@HOST:PORTA/railway"

# Segredo do JWT — gere com: openssl rand -hex 32
AUTH_SECRET="troque-por-um-segredo-aleatorio-forte"

# (opcional) expiração do token de sessão
JWT_EXPIRES_IN="8h"

# Origens permitidas no CORS (separadas por vírgula) — as URLs dos frontends.
WEB_URL="https://crivo-web.vercel.app,https://crivo.vai-sistema.com"

# (opcional) porta local; em produção o host injeta PORT automaticamente.
API_PORT="3333"

# (opcional) intake de lead direto no pipeline do TENANT (não é o funil do
# super admin). Deixe em branco se não for usar.
LEAD_INTAKE_SECRET=""
LEAD_INTAKE_TENANT=""
