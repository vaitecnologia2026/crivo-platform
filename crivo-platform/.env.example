# ── Banco (Postgres) ──
DATABASE_URL="postgresql://crivo:crivo@localhost:5432/crivo?schema=public"

# Usuário de aplicação que respeita RLS (NÃO superuser, NÃO owner da tabela).
# A API conecta com este usuário para que as policies de Row-Level Security sejam aplicadas.
DATABASE_URL_APP="postgresql://crivo_app:crivo_app@localhost:5432/crivo?schema=public"

# ── Cache / filas ──
REDIS_URL="redis://localhost:6379"

# ── Auth ──
AUTH_SECRET="troque-isto-por-um-segredo-forte-de-32+-chars"
JWT_EXPIRES_IN="7d"

# ── IA (Copiloto / RAG) — fase F3 ──
ANTHROPIC_API_KEY=""

# ── App ──
API_PORT=3333
WEB_URL="http://localhost:3000"
API_URL="http://localhost:3333"
