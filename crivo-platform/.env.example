# ── Banco (Postgres) ──
DATABASE_URL="postgresql://crivo:crivo@localhost:5432/crivo?schema=public"

# Usuário de aplicação que respeita RLS (NÃO superuser, NÃO owner da tabela).
# A API conecta com este usuário para que as policies de Row-Level Security sejam aplicadas.
DATABASE_URL_APP="postgresql://crivo_app:crivo_app@localhost:5432/crivo?schema=public"

# ── Cache / filas ──
REDIS_URL="redis://localhost:6379"

# ── Auth ──
AUTH_SECRET="troque-isto-por-um-segredo-forte-de-32+-chars"
JWT_EXPIRES_IN="7d"

# ── IA (Copiloto / RAG) — fase F3 ──
ANTHROPIC_API_KEY=""

# ── App ──
API_PORT=3333
WEB_URL="http://localhost:3000"
API_URL="http://localhost:3333"

# ── Site (apps/site · projeto Vercel crivo-site) ──
# Gate de acesso seguro: validação server-side + cookie httpOnly assinado.
SITE_ACCESS_TOKEN="VAI2026"                           # token digitado no portal
GATE_SECRET="troque-por-um-segredo-forte-32+-chars"   # assina o cookie do gate (HMAC)
# Captura de leads da LP — configure PELO MENOS UM canal:
RESEND_API_KEY=""                                     # e-mail transacional (resend.com)
LEAD_TO_EMAIL="contato@crivolegacy.com.br"            # destino do lead por e-mail
# URL pública da plataforma (botões "Acessar sistema"). Troque para
# https://app.crivolegacy.com.br quando o subdomínio estiver no ar na Vercel.
NEXT_PUBLIC_PLATAFORMA_URL="https://crivo-web.vercel.app/"
LEAD_FROM_EMAIL="CRIVO Leads <onboarding@resend.dev>" # remetente verificado no Resend
LEAD_WEBHOOK_URL=""                                    # POST do lead p/ CRM/Zapier/Make
# Loop captação → pipeline: a LP cria o lead direto no CRM da plataforma.
PLATFORM_API_URL=""                                    # ex.: https://app-api.crivolegacy.com.br/api
LEAD_INTAKE_SECRET=""                                  # mesmo segredo nos dois lados (site + api)

# ── API · intake público de leads (apps/api) ──
LEAD_INTAKE_TENANT=""                                  # organizationId que recebe os leads da LP
# LEAD_INTAKE_SECRET (acima) também é lido pela API para validar o intake.
