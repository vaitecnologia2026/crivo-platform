{
  "name": "crivo-platform",
  "version": "0.1.0",
  "private": true,
  "description": "CRIVO™ Platform — Decision Intelligence System (enterprise SaaS)",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @crivo/db generate",
    "db:migrate": "pnpm --filter @crivo/db migrate",
    "db:rls": "pnpm --filter @crivo/db rls",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
