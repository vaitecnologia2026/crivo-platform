{
  "name": "@crivo/db",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "rls": "psql \"${DATABASE_URL%%\\?*}\" -f prisma/sql/rls.sql",
    "seed": "tsx prisma/seed.ts",
    "test:isolation": "tsx prisma/test-isolation.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@crivo/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
