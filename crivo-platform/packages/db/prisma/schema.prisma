// =====================================================================
// CRIVO™ Platform — Prisma schema
// Fase F0: Tenancy + IAM (fundação). Modelos de F1 (ICD/Assessments)
// entram na próxima fase — ver docs/ARCHITECTURE.md §5.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Papéis (RBAC) ──
enum Role {
  COLABORADOR
  LIDER
  GESTOR
  RH
  JURIDICO
  CEO
  ADMIN
}

enum Plan {
  BASE
  EVOLUCAO
  ENTERPRISE
  ADVISORY
}

enum AssessmentType {
  ICD
  NR1
}

enum CycleStatus {
  OPEN
  CLOSED
}

// Padrão decisório dominante revelado pelo ICD.
enum DominantPattern {
  PRESSAO
  AUTOIMAGEM
  CONFORMIDADE
  AMEACA
  EQUILIBRADO // nenhum driver de risco se destaca (alta coerência)
}

// Estágio do lead no pipeline comercial.
enum LeadStage {
  NOVO
  CONTATO
  QUALIFICADO
  PROPOSTA
  GANHO
  PERDIDO
}

// =====================================================================
// TENANCY — Organization é o tenant raiz (holding). Todo registro de
// negócio carrega tenantId = organizationId e é protegido por RLS.
// =====================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(BASE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]
  units     Unit[]
  teams     Team[]
  users     User[]
  cycles    AssessmentCycle[]
  assessments Assessment[]
  responses Response[]
  icdScores IcdScore[]
  leads     Lead[]

  @@map("organizations")
}

model Company {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  organization   Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  cnpj           String?
  createdAt      DateTime     @default(now())

  units Unit[]

  @@index([tenantId])
  @@map("companies")
}

model Unit {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String       @db.Uuid
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  region    String?
  createdAt DateTime     @default(now())

  teams Team[]

  @@index([tenantId])
  @@index([companyId])
  @@map("units")
}

model Team {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId    String       @db.Uuid
  unit      Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime     @default(now())

  members TeamMember[]

  @@index([tenantId])
  @@index([unitId])
  @@map("teams")
}

// =====================================================================
// IAM
// =====================================================================

model User {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  name         String
  passwordHash String
  role         Role         @default(COLABORADOR)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships TeamMember[]
  assessments Assessment[] @relation("LeaderAssessments")
  icdScores   IcdScore[]   @relation("LeaderScores")

  // E-mail único POR tenant (mesmo e-mail pode existir em orgs diferentes)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model TeamMember {
  teamId   String  @db.Uuid
  userId   String  @db.Uuid
  tenantId String  @db.Uuid
  isLeader Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([tenantId])
  @@map("team_members")
}

// =====================================================================
// AVALIAÇÕES & ICD (Fase F1)
// =====================================================================

model AssessmentCycle {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  status    CycleStatus  @default(OPEN)
  createdAt DateTime     @default(now())

  assessments Assessment[]

  @@index([tenantId])
  @@map("assessment_cycles")
}

model Assessment {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @db.Uuid
  org       Organization    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycleId   String?         @db.Uuid
  cycle     AssessmentCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  leaderId  String          @db.Uuid
  leader    User            @relation("LeaderAssessments", fields: [leaderId], references: [id], onDelete: Cascade)
  type      AssessmentType  @default(ICD)
  createdAt DateTime        @default(now())

  response Response?
  score    IcdScore?

  @@index([tenantId])
  @@index([leaderId])
  @@map("assessments")
}

model Response {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentId String     @unique @db.Uuid
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers      Json       // [{ questionId, value }]
  submittedAt  DateTime   @default(now())

  @@index([tenantId])
  @@map("responses")
}

// =====================================================================
// COMERCIAL — Pipeline de leads (alimentado pela LP e por cadastro manual)
// =====================================================================

model Lead {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  email     String?
  whatsapp  String?
  segment   String?
  origin    String? // lp-diagnostico, lp-ebook-nr1, manual…
  stage     LeadStage    @default(NOVO)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, stage])
  @@map("leads")
}

model IcdScore {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @db.Uuid
  org             Organization    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentId    String          @unique @db.Uuid
  assessment      Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  leaderId        String          @db.Uuid
  leader          User            @relation("LeaderScores", fields: [leaderId], references: [id], onDelete: Cascade)
  score           Int             // 0–100
  dimensions      Json            // { clareza, pressao, confianca, influencia, risco } (0–100, normalizado p/ coerência)
  dominantPattern DominantPattern
  computedAt      DateTime        @default(now())

  @@index([tenantId])
  @@index([leaderId])
  @@map("icd_scores")
}
