// =====================================================================
// CRIVO™ Platform — Prisma schema
// Fase F0: Tenancy + IAM (fundação). Modelos de F1 (ICD/Assessments)
// entram na próxima fase — ver docs/ARCHITECTURE.md §5.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Papéis (RBAC) ──
enum Role {
  COLABORADOR
  LIDER
  GESTOR
  RH
  JURIDICO
  CEO
  ADMIN
}

enum Plan {
  BASE
  EVOLUCAO
  ENTERPRISE
  ADVISORY
}

// =====================================================================
// TENANCY — Organization é o tenant raiz (holding). Todo registro de
// negócio carrega tenantId = organizationId e é protegido por RLS.
// =====================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(BASE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]
  units     Unit[]
  teams     Team[]
  users     User[]

  @@map("organizations")
}

model Company {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  organization   Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  cnpj           String?
  createdAt      DateTime     @default(now())

  units Unit[]

  @@index([tenantId])
  @@map("companies")
}

model Unit {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String       @db.Uuid
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  region    String?
  createdAt DateTime     @default(now())

  teams Team[]

  @@index([tenantId])
  @@index([companyId])
  @@map("units")
}

model Team {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId    String       @db.Uuid
  unit      Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime     @default(now())

  members TeamMember[]

  @@index([tenantId])
  @@index([unitId])
  @@map("teams")
}

// =====================================================================
// IAM
// =====================================================================

model User {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  name         String
  passwordHash String
  role         Role         @default(COLABORADOR)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships TeamMember[]

  // E-mail único POR tenant (mesmo e-mail pode existir em orgs diferentes)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model TeamMember {
  teamId   String  @db.Uuid
  userId   String  @db.Uuid
  tenantId String  @db.Uuid
  isLeader Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([tenantId])
  @@map("team_members")
}
