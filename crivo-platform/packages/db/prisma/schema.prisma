// =====================================================================
// CRIVO™ Platform — Prisma schema
// Fase F0: Tenancy + IAM (fundação). Modelos de F1 (ICD/Assessments)
// entram na próxima fase — ver docs/ARCHITECTURE.md §5.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Papéis (RBAC) ──
enum Role {
  COLABORADOR
  LIDER
  GESTOR
  RH
  JURIDICO
  CEO
  ADMIN
}

enum Plan {
  BASE
  EVOLUCAO
  ENTERPRISE
  ADVISORY
}

enum AssessmentType {
  ICD
  NR1
}

enum CycleStatus {
  OPEN
  CLOSED
}

// Tensão decisória dominante revelada pelo ICD (modelo dos 4 Rs). Substitui o
// antigo "padrão dominante". O nome do enum é mantido por compatibilidade.
enum DominantPattern {
  REATIVIDADE
  RIGIDEZ
  REPERCUSSAO
  RISCO
  EQUILIBRADO // nenhum R se destaca (alta coerência)
}

// Estágio do lead no pipeline comercial.
enum LeadStage {
  NOVO
  CONTATO
  QUALIFICADO
  PROPOSTA
  GANHO
  PERDIDO
}

// Estado de uma empresa-cliente no control plane.
enum TenantStatus {
  ACTIVE
  SUSPENDED // bloqueada: usuários não conseguem logar
  DELETED // exclusão lógica (reversível); purge físico é operação separada
}

// Estado de um Produto no catálogo comercial (control plane).
enum ProductStatus {
  DRAFT // em construção, não vendável
  ACTIVE // publicado, pode ser contratado
  INACTIVE // arquivado
}

// Estágio do lead no funil comercial da CRIVO (CRM do Super Admin). Espelha o
// Kanban do Portal PDF (Print 2): NOVO → PRÉ-DIAGNÓSTICO → REUNIÃO → PROPOSTA →
// FECHADO (+ PERDIDO). Distinto de LeadStage (pipeline interno do tenant).
enum PlatformLeadStage {
  NOVO
  PRE_DIAGNOSTICO
  REUNIAO
  PROPOSTA
  FECHADO
  PERDIDO
}

// MÉTODO CRIVO — como a avaliação é conduzida (Briefing §4). Porte/complexidade
// definem o método.
enum DiagnosticMethod {
  INICIAL
  ESSENCIAL
  ORGANIZACIONAL
}

// SAÍDA TÉCNICA — quais documentos são gerados (Briefing §4). Obrigação
// documental define a saída — independente do método. PGR não obriga Organizacional.
enum TechnicalOutput {
  SEM_INTEGRACAO // leitura preliminar, sem caráter AEP/PGR
  AEP // apoio à AEP
  AEP_PGR // apoio à AEP + PGR
}

// Modelo de contratação (Matriz §Contrato): define prazo e recorrência.
enum ContractModel {
  PONTUAL
  SEIS_MESES
  DOZE_MESES
  VINTE_QUATRO_MESES
  CUSTOM
}

// Estado do contrato de um cliente.
enum ContractStatus {
  RASCUNHO
  ATIVO
  SUSPENSO
  ENCERRADO
}

// Status de uma ação do plano (Matriz §Plano de Ação).
enum ActionStatus {
  SUGERIDA
  EM_REVISAO
  APROVADA
  EM_ANDAMENTO
  CONCLUIDA
  REAVALIADA
}

// Tipo de registro do Diagnóstico Essencial (Briefing §5): escuta com empregados
// ou observação/análise da atividade.
enum EssentialRecordKind {
  ESCUTA
  OBSERVACAO
}

// =====================================================================
// CONTROL PLANE (F1) — registro GLOBAL de empresas-cliente e super admins.
// NÃO é escopado por tenant: estas tabelas ficam FORA da RLS por tenant.
// Acesso EXCLUSIVO via conexão owner (prisma.admin) pelo módulo Admin —
// o papel crivo_app tem o acesso REVOGADO (ver prisma/sql/rls.sql).
// Ver docs/SAAS-TRANSFORMATION.md §3 (Control Plane × Data Plane).
// =====================================================================

// Nível 1 — Super Administrador global. Principal SEPARADO do RBAC de tenant
// (não é um User com papel; vive no control plane, sem tenantId).
model SuperAdmin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  active       Boolean  @default(true)
  totpSecret   String? // segredo TOTP (definido no setup; pode existir "pendente")
  totpEnabled  Boolean  @default(false) // MFA ativo? exige código no login
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

// Registro mestre de cada empresa-cliente (espelha Organization no data plane).
// Liga ao Organization por organizationId SEM relation Prisma, para manter o
// control plane desacoplado do modelo RLS — relação 1:1 lógica.
model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid // → organizations.id (data plane)
  slug           String       @unique // subdomínio: <slug>.crivolegacy.com.br
  name           String
  plan           Plan         @default(BASE)
  status         TenantStatus @default(ACTIVE)
  productId      String?      @db.Uuid // → products.id: produto que originou a empresa (FASE 3)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tenants")
}

// Trilha de auditoria das ações de plataforma (F2). Control plane: owner-only
// (sem RLS por tenant; crivo_app sem acesso). tenantId null = ação global de
// super admin. Append-only na prática (escrita best-effort pelo módulo Admin).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @db.Uuid // null = ação de super admin (global)
  actorId    String?
  actorEmail String?
  action     String // tenant.provision | tenant.suspend | tenant.activate | tenant.delete | admin.login
  target     String? // id/slug do alvo
  meta       Json?
  at         DateTime @default(now())

  @@index([tenantId])
  @@index([at])
  @@map("audit_log")
}

// =====================================================================
// PRODUTOS (núcleo product-driven) — TUDO nasce de um Produto. Um produto
// define preço, limites, módulos liberados, o INSTRUMENTO de diagnóstico
// (perguntas editáveis) e a configuração de IA dos líderes. Ao converter um
// lead em cliente, a empresa é provisionada A PARTIR do produto contratado.
// Control plane (owner-only): catálogo global, fora da RLS por tenant.
// Ver diretriz estrutural 2026-06 (Super Admin product-driven).
// =====================================================================
model Product {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique // pre-diagnostico-crivo, crivo-enterprise…
  name        String
  description String?
  status      ProductStatus @default(DRAFT)
  plan        Plan? // plano-base herdado pela empresa (opcional)

  // Dados gerais / comercial
  monthlyPriceCents Int     @default(0) // valor mensal (centavos)
  setupPriceCents   Int     @default(0) // valor de implantação (centavos)
  maxUsers          Int     @default(0) // 0 = ilimitado
  maxLeaders        Int     @default(0) // 0 = ilimitado
  companyType       String? // tipo de empresa atendida

  // Módulos liberados: códigos do ModuleCatalog habilitados por este produto.
  modules Json @default("[]") // string[] de moduleCode

  // Método CRIVO deste produto + saídas técnicas que ele pode gerar (Briefing §4).
  // coreModules = liberados automaticamente na contratação (CORE da Matriz).
  method           DiagnosticMethod?
  coreModules      Json              @default("[]") // string[] de moduleCode (CORE)
  supportedOutputs Json              @default("[]") // TechnicalOutput[] suportados

  // Instrumento de diagnóstico EDITÁVEL (não fixo): blocos, categorias,
  // dimensões, escalas de resposta, pesos e perguntas. Cada produto tem o seu.
  // { dimensions:[{key,label}], scales:[{key,label,options:[{value,label}]}],
  //   blocks:[{key,label}], questions:[{id,text,block,dimension,scale,weight,inverse}] }
  diagnostic Json?

  // Configuração da IA dos líderes (por produto).
  // { prompt, knowledgeBase, rules, limitations, objective, documents:[] }
  aiConfig Json?

  // Produto de captura (pré-diagnóstico): só LP/formulário/lead — SEM portal,
  // SEM app, SEM IA. Usado pelo funil comercial da CRIVO.
  isLeadCapture Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// =====================================================================
// CRM DO SUPER ADMIN — funil comercial da CRIVO. O lead nasce do Diagnóstico
// Inicial da Landing Page (ou cadastro manual) e pertence ao SUPER ADMIN, não
// a uma empresa. Control plane (owner-only). Ao fechar a venda, é convertido
// em Tenant (convertedTenantId) provisionando a empresa pelo produto.
// =====================================================================
model PlatformLead {
  id             String  @id @default(uuid()) @db.Uuid
  name           String
  company        String?
  email          String?
  phone          String?
  segment        String?
  employeesCount String? // faixa ("51-200") ou número informado
  origin         String? // lp-diagnostico | qrcode | indicacao | anuncio…
  productId      String? @db.Uuid // produto de origem (ex.: pré-diagnóstico)

  // Resultado do pré-diagnóstico (leitura preliminar — não é ICD oficial).
  diagnosticScore  Int? // 0–100 (score geral)
  diagnosticResult Json? // { score, level, byDimension, topConcern, recommendation }

  stage             PlatformLeadStage @default(NOVO)
  notes             String?
  convertedTenantId String?           @db.Uuid // tenant criado na conversão (FASE 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([createdAt])
  @@map("platform_leads")
}

// =====================================================================
// CONTRATO (Briefing §11 + Matriz §Super Admin) — o que a CRIVO configura por
// cliente SEM programação: produto, modelo, prazo, rodadas, respondentes,
// líderes, integração técnica (AEP/PGR), módulos opcionais, responsável e
// status. Control plane (owner-only). Um contrato ATIVO por empresa; histórico
// permitido. O portal libera menus a partir do produto (CORE) + opcionais.
// =====================================================================
model Contract {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid // → organizations.id (empresa-cliente)
  productId      String?        @db.Uuid // → products.id (produto contratado)
  model          ContractModel  @default(PONTUAL)
  status         ContractStatus @default(RASCUNHO)

  // Método é herdado do produto, mas pode ser sobrescrito por contrato.
  method          DiagnosticMethod?
  // Saída técnica define os documentos gerados — independente do método.
  technicalOutput TechnicalOutput   @default(SEM_INTEGRACAO)

  startDate      DateTime?
  endDate        DateTime?
  accessDays     Int? // prazo de acesso (dias) — alternativa a endDate
  rounds         Int       @default(1) // rodadas/ciclos/pulsos
  maxRespondents Int       @default(0) // 0 = ilimitado
  maxLeaders     Int       @default(0)

  // Módulos opcionais ativados além do CORE do produto (códigos do ModuleCatalog).
  optionalModules Json    @default("[]")
  responsible     String? // responsável CRIVO pelo contrato
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("contracts")
}

// =====================================================================
// CONFIGURAÇÃO DE IA (Super Admin · auditoria 2.3.1) — token OpenAI/ChatGPT
// configurável SEM código, CRIPTOGRAFADO em repouso (AES-256-GCM com chave
// derivada de AUTH_SECRET). Singleton (scope='global'). Control plane
// (owner-only): nenhum usuário comum lê o token. Prompts por produto vivem em
// Product.aiConfig; aqui ficam token, modelo, ativação e módulos habilitados.
// =====================================================================
model AiSettings {
  id       String @id @default(uuid()) @db.Uuid
  scope    String @unique @default("global")
  provider String @default("openai")
  model    String @default("gpt-4o-mini")

  // Token criptografado (nunca em claro no banco nem na API de leitura).
  apiKeyEnc  String? // ciphertext base64
  apiKeyIv   String? // IV base64
  apiKeyTag  String? // auth tag base64 (GCM)
  apiKeyHint String? // últimos 4 chars, p/ exibir mascarado

  enabled        Boolean   @default(false)
  enabledModules Json      @default("[]") // string[] de moduleCode que podem usar IA
  lastStatus     String? // ok | invalid | error | rate_limited | untested
  lastTestedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_settings")
}

// =====================================================================
// RBAC DINÂMICO (F3) — catálogo GLOBAL de permissões (módulo:ação) e papéis
// de sistema. Sem RLS por tenant (catálogo compartilhado entre todas as
// empresas); SOMENTE-LEITURA para o app — escrita só via seed/owner (rls.sql).
// Papéis customizados POR empresa e atribuição multi-papel (UserRole) entram
// na próxima fatia. Ver docs/SAAS-TRANSFORMATION.md §6.
// =====================================================================

model Permission {
  id     String           @id @default(uuid()) @db.Uuid
  code   String           @unique // "leads:view"
  module String // leads
  action String // view | create | edit | delete | export | submit
  label  String
  roles  RolePermission[]

  @@map("permissions")
}

model RoleDef {
  id       String           @id @default(uuid()) @db.Uuid
  code     String           @unique // espelha o enum Role: ADMIN, CEO, GESTOR, RH, LIDER, JURIDICO, COLABORADOR
  name     String
  isSystem Boolean          @default(true)
  perms    RolePermission[]

  @@map("role_defs")
}

model RolePermission {
  roleId String     @db.Uuid
  permId String     @db.Uuid
  role   RoleDef    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  perm   Permission @relation(fields: [permId], references: [id], onDelete: Cascade)

  @@id([roleId, permId])
  @@map("role_permissions")
}

// =====================================================================
// PLANOS + MÓDULOS (F4) — catálogo GLOBAL de módulos da plataforma e a
// ativação por empresa. ModuleCatalog é compartilhado (sem RLS por tenant,
// SOMENTE-LEITURA p/ o app, como o catálogo RBAC). TenantModule é DATA PLANE
// (RLS por tenant): o app lê os módulos da própria empresa via forTenant; a
// ESCRITA é owner-only (super admin), para uma empresa não auto-habilitar
// módulos que não contratou. Ver docs/SAAS-TRANSFORMATION.md §4.
// =====================================================================

model ModuleCatalog {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique // dashboard | icd | crm | relatorios | ...
  name      String
  category  String
  minPlan   Plan     @default(BASE) // plano mínimo p/ habilitar
  createdAt DateTime @default(now())

  @@map("module_catalog")
}

// Domínios próprios por empresa (F5). A resolução por domínio acontece ANTES
// de conhecer o tenant (pré-login), então tenant_domains é CONTROL PLANE:
// acesso só via owner (crivo_app revogado no rls.sql). organizationId liga ao
// data plane (sem relation Prisma p/ manter o desacoplamento, como Tenant).
model TenantDomain {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid // → organizations.id (data plane)
  domain         String   @unique // app.clientex.com | clientex.crivolegacy.com.br
  verified       Boolean  @default(false)
  primary        Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("tenant_domains")
}

// White-label (F5): identidade visual por empresa. 1:1 com Organization.
// Data plane (RLS por tenant): a plataforma lê a própria via forTenant; a
// escrita é owner-only (super admin define), como tenant_modules. As cores
// sobrescrevem os tokens --crivo-* (primária = azul-profundo, acento = terra).
model TenantBranding {
  tenantId     String       @id @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl      String?
  faviconUrl   String?
  primaryColor String? // hex, sobrescreve --crivo-azul-profundo
  accentColor  String? // hex, sobrescreve --crivo-terra
  emailFrom    String?
  whatsapp     String?
  footerText   String?
  updatedAt    DateTime     @updatedAt

  @@map("tenant_branding")
}

// Biblioteca & Formação: conteúdo (materiais/cursos) por empresa. Data plane
// (RLS por tenant): a empresa vê/gere o próprio acervo. Escrita gateada por
// `library:manage` na API; leitura por `library:view`.
model LibraryItem {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  org         Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  kind        String // artigo | podcast | ebook | curso | framework
  url         String?
  createdAt   DateTime     @default(now())

  @@index([tenantId])
  @@map("library_items")
}

// Metering (F4): contadores de uso por empresa/métrica/período (YYYY-MM).
// Data plane (RLS por tenant): o app incrementa sob forTenant. Base p/ billing
// e enforcement de limites de plano (PLAN_LIMITS).
model UsageCounter {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric    String // leads | api_calls | active_users
  period    String // YYYY-MM
  value     BigInt       @default(0)
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, metric, period])
  @@index([tenantId])
  @@map("usage_counters")
}

// Quais módulos a empresa ativou. PK composta (tenant + módulo). tenantId =
// organizationId (data plane). config reservado p/ parametrização por módulo.
model TenantModule {
  tenantId   String       @db.Uuid
  org        Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleCode String
  enabled    Boolean      @default(true)
  config     Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@id([tenantId, moduleCode])
  @@index([tenantId])
  @@map("tenant_modules")
}

// =====================================================================
// TENANCY — Organization é o tenant raiz (holding). Todo registro de
// negócio carrega tenantId = organizationId e é protegido por RLS.
// =====================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(BASE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies        Company[]
  units            Unit[]
  teams            Team[]
  users            User[]
  cycles           AssessmentCycle[]
  assessments      Assessment[]
  responses        Response[]
  icdScores        IcdScore[]
  leads            Lead[]
  modules          TenantModule[]
  usage            UsageCounter[]
  branding         TenantBranding?
  library          LibraryItem[]
  actionPlans      ActionPlan[]
  actionItems      ActionItem[]
  evidences        Evidence[]
  selfAssessments  SelfAssessment[]
  essentialRecords EssentialRecord[]

  @@map("organizations")
}

model Company {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  cnpj         String?
  createdAt    DateTime     @default(now())

  units Unit[]

  @@index([tenantId])
  @@map("companies")
}

model Unit {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String       @db.Uuid
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  region    String?
  createdAt DateTime     @default(now())

  teams Team[]

  @@index([tenantId])
  @@index([companyId])
  @@map("units")
}

model Team {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId    String       @db.Uuid
  unit      Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime     @default(now())

  members TeamMember[]

  @@index([tenantId])
  @@index([unitId])
  @@map("teams")
}

// =====================================================================
// IAM
// =====================================================================

model User {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  name         String
  passwordHash String
  role         Role         @default(COLABORADOR)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships TeamMember[]
  assessments Assessment[] @relation("LeaderAssessments")
  icdScores   IcdScore[]   @relation("LeaderScores")

  // E-mail único POR tenant (mesmo e-mail pode existir em orgs diferentes)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model TeamMember {
  teamId   String  @db.Uuid
  userId   String  @db.Uuid
  tenantId String  @db.Uuid
  isLeader Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([tenantId])
  @@map("team_members")
}

// =====================================================================
// AVALIAÇÕES & ICD (Fase F1)
// =====================================================================

model AssessmentCycle {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  status    CycleStatus  @default(OPEN)
  createdAt DateTime     @default(now())

  assessments Assessment[]

  @@index([tenantId])
  @@map("assessment_cycles")
}

model Assessment {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid
  org       Organization     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycleId   String?          @db.Uuid
  cycle     AssessmentCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  leaderId  String           @db.Uuid
  leader    User             @relation("LeaderAssessments", fields: [leaderId], references: [id], onDelete: Cascade)
  type      AssessmentType   @default(ICD)
  createdAt DateTime         @default(now())

  response Response?
  score    IcdScore?

  @@index([tenantId])
  @@index([leaderId])
  @@map("assessments")
}

model Response {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentId String       @unique @db.Uuid
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers      Json // [{ questionId, value }]
  submittedAt  DateTime     @default(now())

  @@index([tenantId])
  @@map("responses")
}

// =====================================================================
// COMERCIAL — Pipeline de leads (alimentado pela LP e por cadastro manual)
// =====================================================================

model Lead {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  email     String?
  whatsapp  String?
  segment   String?
  origin    String? // lp-diagnostico, lp-ebook-nr1, manual…
  stage     LeadStage    @default(NOVO)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, stage])
  @@map("leads")
}

model IcdScore {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @db.Uuid
  org             Organization    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentId    String          @unique @db.Uuid
  assessment      Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  leaderId        String          @db.Uuid
  leader          User            @relation("LeaderScores", fields: [leaderId], references: [id], onDelete: Cascade)
  score           Int // 0–100
  dimensions      Json // { clareza, pressao, confianca, influencia, risco } (0–100, normalizado p/ coerência)
  dominantPattern DominantPattern
  computedAt      DateTime        @default(now())

  @@index([tenantId])
  @@index([leaderId])
  @@map("icd_scores")
}

// =====================================================================
// PLANO DE AÇÃO + EVIDÊNCIAS (Briefing §8/§9 + Matriz §Plano de Ação) — CORE de
// todo diagnóstico. Data plane (RLS por tenant). O plano final só vira documento
// após validação pela empresa/responsável (validatedAt). Ações podem ser
// sugeridas (IA/biblioteca), mas a validação é humana.
// =====================================================================
model ActionPlan {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  org         Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  source      String? // autoavaliação | escuta | questionário | observação | parecer
  validatedAt DateTime? // sem validação = minuta; com validação = documento final
  validatedBy String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items ActionItem[]

  @@index([tenantId])
  @@map("action_plans")
}

model ActionItem {
  id               String       @id @default(uuid()) @db.Uuid
  tenantId         String       @db.Uuid
  org              Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String       @db.Uuid
  plan             ActionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  point            String // ponto identificado
  origin           String? // origem do ponto (autoavaliação/escuta/questionário/observação/parecer)
  action           String // ação proposta
  responsible      String? // responsável (empresa)
  dueDate          DateTime?
  status           ActionStatus @default(SUGERIDA)
  expectedEvidence String? // evidência esperada
  reviewDate       DateTime? // data de revisão de efetividade
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  evidences Evidence[]

  @@index([tenantId])
  @@index([planId])
  @@map("action_items")
}

model Evidence {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId    String?      @db.Uuid // vínculo opcional com a ação
  item      ActionItem?  @relation(fields: [itemId], references: [id], onDelete: SetNull)
  kind      String // ata | reuniao | print | foto | documento | comunicado | lista | treinamento | link
  title     String
  url       String? // link ou caminho do arquivo
  note      String?
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@index([itemId])
  @@map("evidences")
}

// =====================================================================
// DIAGNÓSTICO ESSENCIAL (Briefing §5) — jornada simples para empresas pequenas:
// autoavaliação guiada + registro de escuta/observação → pontos de atenção que
// alimentam o Plano de Ação e o dossiê AEP/AEP+PGR. Data plane (RLS por tenant).
// =====================================================================
model SelfAssessment {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers   Json // [{ questionId, value }]
  score     Int // 0–100 (maturidade)
  result    Json // { score, level, byDimension, topAttention }
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@map("self_assessments")
}

model EssentialRecord {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @db.Uuid
  org          Organization        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind         EssentialRecordKind
  title        String
  recordDate   DateTime?
  participants String? // quem participou da escuta / contexto da observação
  notes        String?
  points       String? // pontos de atenção identificados
  createdAt    DateTime            @default(now())

  @@index([tenantId])
  @@map("essential_records")
}
