// =====================================================================
// CRIVO™ Platform — Prisma schema
// Fase F0: Tenancy + IAM (fundação). Modelos de F1 (ICD/Assessments)
// entram na próxima fase — ver docs/ARCHITECTURE.md §5.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Papéis (RBAC) ──
enum Role {
  COLABORADOR
  LIDER
  GESTOR
  RH
  JURIDICO
  CEO
  ADMIN
  CONSULTOR
  MENTOR
  ACADEMIA
}

enum Plan {
  BASE
  EVOLUCAO
  ENTERPRISE
  ADVISORY
}

enum AssessmentType {
  ICD
  NR1
}

enum CycleStatus {
  OPEN
  CLOSED
}

// Tensão decisória dominante revelada pelo ICD (modelo dos 4 Rs). Substitui o
// antigo "padrão dominante". O nome do enum é mantido por compatibilidade.
enum DominantPattern {
  REATIVIDADE
  RIGIDEZ
  REPERCUSSAO
  RISCO
  EQUILIBRADO // nenhum R se destaca (alta coerência)
}

// Estágio do lead no pipeline comercial.
enum LeadStage {
  NOVO
  CONTATO
  QUALIFICADO
  PROPOSTA
  GANHO
  PERDIDO
}

// Estado de uma empresa-cliente no control plane.
enum TenantStatus {
  ACTIVE
  SUSPENDED // bloqueada: usuários não conseguem logar
  DELETED // exclusão lógica (reversível); purge físico é operação separada
}

// Estado de um Produto no catálogo comercial (control plane).
enum ProductStatus {
  DRAFT // em construção, não vendável
  ACTIVE // publicado, pode ser contratado
  INACTIVE // arquivado
}

// Estágio do lead no funil comercial da CRIVO (CRM do Super Admin). Espelha o
// Kanban do Portal PDF (Print 2): NOVO → PRÉ-DIAGNÓSTICO → REUNIÃO → PROPOSTA →
// FECHADO (+ PERDIDO). Distinto de LeadStage (pipeline interno do tenant).
// Ciclo comercial completo (PDF §4.2 CRM Interno): da captação ao pós-venda.
// Valores antigos (PRE_DIAGNOSTICO/REUNIAO) mantidos p/ compatibilidade de dados.
enum PlatformLeadStage {
  NOVO
  PRE_DIAGNOSTICO
  REUNIAO
  OPORTUNIDADE
  PROPOSTA
  FECHADO
  CONTRATO
  ONBOARDING
  IMPLANTACAO
  ENTREGA
  SUSTENTACAO
  RENOVACAO
  UPSELL
  PERDIDO
}

// MÉTODO CRIVO — como a avaliação é conduzida (Briefing §4). Porte/complexidade
// definem o método.
enum DiagnosticMethod {
  INICIAL
  ESSENCIAL
  ORGANIZACIONAL
}

// SAÍDA TÉCNICA — quais documentos são gerados (Briefing §4). Obrigação
// documental define a saída — independente do método. PGR não obriga Organizacional.
enum TechnicalOutput {
  SEM_INTEGRACAO // leitura preliminar, sem caráter AEP/PGR
  AEP // apoio à AEP
  AEP_PGR // apoio à AEP + PGR
}

// Modelo de contratação (Matriz §Contrato): define prazo e recorrência.
enum ContractModel {
  PONTUAL
  SEIS_MESES
  DOZE_MESES
  VINTE_QUATRO_MESES
  CUSTOM
}

// Estado do contrato de um cliente.
enum ContractStatus {
  RASCUNHO
  ATIVO
  SUSPENSO
  ENCERRADO
}

// Status de uma ação do plano (Matriz §Plano de Ação).
enum ActionStatus {
  SUGERIDA
  EM_REVISAO
  APROVADA
  EM_ANDAMENTO
  CONCLUIDA
  REAVALIADA
}

// Tipo de registro do Diagnóstico Essencial (Briefing §5): escuta com empregados
// ou observação/análise da atividade.
enum EssentialRecordKind {
  ESCUTA
  OBSERVACAO
}

// =====================================================================
// REGISTRO DE DECISÃO (Anexo Técnico ICD do Líder v1, §5–§9).
// Base operacional do ICD: o líder registra decisões reais; o ICD avalia
// a coerência da decisão em 4 eixos (Clareza/Critério/Alinhamento/Sustentação).
// Os enums abaixo cobrem os campos visíveis ao líder (§5.1) e a regra
// de impacto/peso (§9.3). Os modelos de scoring e ciclo vêm nas próximas
// migrations (tasks #46 e #47).
// =====================================================================

// Anexo ICD §5.1 e §9.3 — define peso na média ponderada trimestral.
// BAIXO=0 (fica só no histórico, não entra no ICD oficial); MEDIO=1; ALTO=2.
enum DecisionImpact {
  BAIXO
  MEDIO
  ALTO
}

// Anexo ICD §5.1 — natureza da decisão.
enum DecisionType {
  INDIVIDUAL
  COLETIVA
  RECOMENDACAO_APROVACAO
  COMPARTILHADA
}

// Anexo ICD §5.1 — correlação com uso do Pocket antes/durante a decisão.
enum DecisionPocketUse {
  NAO_UTILIZADO
  ANTES
  DURANTE
}

// Anexo ICD §5.1 — principal fator de pressão sobre a decisão.
enum DecisionPressureFactor {
  URGENCIA
  CONFLITO
  FALTA_INFORMACAO
  PRESSAO_RESULTADO
  RISCO_FINANCEIRO
  RISCO_PESSOAS
  RISCO_JURIDICO
  EXPOSICAO_REPUTACIONAL
  OUTRO
}

// Anexo ICD §5.1 — janela para revisão futura da decisão.
enum DecisionRevisionPeriod {
  D30
  D60
  D90
  SEM_REVISAO
}

// Anexo ICD §5.3 — ciclo de vida da decisão. EM_REGISTRO = rascunho;
// REGISTRADA = no histórico, sem ICD; AVALIADA_PELO_ICD = ICD completo
// respondido. A elegibilidade para o oficial é derivada (impact ≠ BAIXO).
enum DecisionStatus {
  EM_REGISTRO
  REGISTRADA
  AVALIADA_PELO_ICD
}

// Anexo ICD §6 — quatro EIXOS oficiais (substituem os 4 Rs do modelo legado).
// Cada eixo é medido por 2 afirmações (P1-P8, §7) em escala 1–5; o score do
// eixo é a média dos dois scores convertidos (§9.1). O ICD da decisão é a
// média dos 4 eixos (§9.2).
enum IcdAxis {
  CLAREZA // P1/P2 — fatos, dados e lacunas reconhecidas antes da conclusão.
  CRITERIO // P3/P4 — discernimento, prioridade e consistência sob pressão.
  ALINHAMENTO // P5/P6 — pessoas, áreas, processos, comunicação considerados.
  SUSTENTACAO // P7/P8 — coerência com estratégia/cultura/valores; horizonte longo.
}

// Anexo ICD §9.6 — ciclo trimestral do ICD. OPEN = parcial (atualiza ao vivo
// conforme decisões são avaliadas); CLOSED = oficial, congelado para histórico.
enum IcdCycleStatus {
  OPEN
  CLOSED
}

// =====================================================================
// POCKET CRIVO / INTERNAL ENGINE (Anexo Técnico Pocket v1).
// Módulo de Liderança/App: prepara o líder ANTES ou DURANTE decisões
// relevantes via 10 perguntas reflexivas (C1-O2) nas 5 dimensões CRIVO.
// NÃO gera score (§6) e NÃO é avaliação — é apoio metacognitivo (§3).
// =====================================================================

// Anexo Pocket §8 — quando o líder usa o Pocket em relação à decisão.
enum PocketMomentOfUse {
  AVULSO // reflexão sem decisão específica
  ANTES_DECISAO
  DURANTE_DECISAO
}

// Estado da sessão Pocket. EM_ANDAMENTO = pelo menos uma pergunta respondida;
// CONCLUIDA = líder marcou fim. Histórico individual (§13).
enum PocketSessionStatus {
  EM_ANDAMENTO
  CONCLUIDA
}

// Estado de um Relatório Preliminar CRIVO (Diagnóstico Inicial, §7).
// GERANDO → IA está produzindo o conteúdo;
// PRONTO  → conteúdo gerado, ainda não enviado;
// ENVIADO → e-mail entregue ao provider (não significa entregue ao usuário);
// ERRO    → falhou em gerar OU enviar (errorReason preenchido).
enum PreliminaryReportStatus {
  GERANDO
  PRONTO
  ENVIADO
  ERRO
}

// =====================================================================
// RBAC DINÂMICO POR TENANT (#68) — papéis customizados por empresa.
// User.role (enum) continua existindo como FALLBACK; um usuário também
// pode receber 1..N TenantRole (multi-papel). PermissionService combina
// ambos para resolver as permissões efetivas.
// Vive no DATA PLANE (tem tenantId, sob RLS).
// =====================================================================

model TenantRole {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  org         Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Slug curto e estável (ex: "lider_comercial"). Único por tenant.
  code        String
  name        String
  description String?
  // Lista de Permission.code (ex: "leads:view", "icd:submit"). Validada no service.
  permissions String[]     @default([])
  // Marca papéis criados via UI vs seed (não é o enum global Role, que é "system").
  isCustom    Boolean      @default(true)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userRoles UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("tenant_roles")
}

model UserRole {
  userId       String     @db.Uuid
  tenantRoleId String     @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantRole   TenantRole @relation(fields: [tenantRoleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
  assignedBy   String? // e-mail/nome do operador que atribuiu

  @@id([userId, tenantRoleId])
  @@index([tenantRoleId])
  @@map("user_roles")
}

// Mentoria (Matriz §Mentorias / Briefing §10). Formato e status controlados.
enum MentoriaFormat {
  ONLINE
  PRESENCIAL
  HIBRIDA
}

enum MentoriaStatus {
  AGENDADA
  REALIZADA
  CANCELADA
  REAGENDADA
}

// =====================================================================
// CONTROL PLANE (F1) — registro GLOBAL de empresas-cliente e super admins.
// NÃO é escopado por tenant: estas tabelas ficam FORA da RLS por tenant.
// Acesso EXCLUSIVO via conexão owner (prisma.admin) pelo módulo Admin —
// o papel crivo_app tem o acesso REVOGADO (ver prisma/sql/rls.sql).
// Ver docs/SAAS-TRANSFORMATION.md §3 (Control Plane × Data Plane).
// =====================================================================

// Nível 1 — Super Administrador global. Principal SEPARADO do RBAC de tenant
// (não é um User com papel; vive no control plane, sem tenantId).
model SuperAdmin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  active       Boolean  @default(true)
  totpSecret   String? // segredo TOTP (definido no setup; pode existir "pendente")
  totpEnabled  Boolean  @default(false) // MFA ativo? exige código no login
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

// Registro mestre de cada empresa-cliente (espelha Organization no data plane).
// Liga ao Organization por organizationId SEM relation Prisma, para manter o
// control plane desacoplado do modelo RLS — relação 1:1 lógica.
model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid // → organizations.id (data plane)
  slug           String       @unique // subdomínio: <slug>.crivolegacy.com.br
  name           String
  plan           Plan         @default(BASE)
  status         TenantStatus @default(ACTIVE)
  productId      String?      @db.Uuid // → products.id: produto que originou a empresa (FASE 3)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tenants")
}

// Relatório Preliminar CRIVO (Briefing §5, Portal §7).
// Control plane: gerado a partir de PlatformLead (Diagnóstico Inicial preenchido
// na LP). Conteúdo produzido pela IA (mesmo provider do Copiloto) a partir do
// snapshot do diagnóstico. Envio por e-mail é best-effort (graceful fallback).
// Sem RLS por tenant — não pertence a um tenant; pertence ao funil do super admin.
model PreliminaryReport {
  id             String @id @default(uuid()) @db.Uuid
  platformLeadId String @db.Uuid // → platform_leads.id (sem relation Prisma para manter desacoplado)

  // Snapshot do diagnóstico no momento da geração (imutável, mesmo se o lead
  // refizer o diagnóstico depois).
  diagnosticScore      Int
  diagnosticLevel      String // INICIAL | EM_ESTRUTURACAO | ESTRUTURADO | AVANCADO
  diagnosticDimensions Json // Record<PreDiagnosticDimension, number>
  topAttention         String

  // Conteúdo do relatório (markdown), modelo usado e versão do prompt.
  content       String
  modelVersion  String // ex: gpt-4o-mini / claude-sonnet-4-6
  promptVersion String @default("v1")

  status      PreliminaryReportStatus @default(GERANDO)
  errorReason String?

  // Envio por e-mail.
  sentTo        String? // endereço do destinatário
  sentAt        DateTime?
  emailProvider String? // resend | smtp | stub

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platformLeadId])
  @@index([status])
  @@map("preliminary_reports")
}

// Mentoria de líder (Briefing §10, Matriz §Mentorias). Vinculada a um tenant
// (ID lógico, sem relation Prisma para manter control plane desacoplado).
// Super Admin agenda, controla formato/quantidade/status; o cliente vê o
// histórico/calendário (próxima fatia da UI do tenant).
model Mentoria {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid // → organizations.id (sem relation)
  title        String
  format       MentoriaFormat @default(ONLINE)
  mentorName   String
  // Líder/colaborador convidado — armazenado como string (e-mail/nome) para
  // permitir mentoria de pessoas que ainda não estão no app.
  attendee     String
  scheduledAt  DateTime
  durationMin  Int            @default(60)
  meetingUrl   String? // para ONLINE
  location     String? // para PRESENCIAL
  status       MentoriaStatus @default(AGENDADA)
  notes        String?
  recordingUrl String? // gravação / ata após realizada
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId])
  @@index([scheduledAt])
  @@index([status])
  @@map("mentorias")
}

// Biblioteca de Ações (Matriz §Plano de Ação): catálogo GLOBAL de ações
// modelo que o RH/CEO da empresa pode IMPORTAR para o próprio plano. Sem RLS.
// Cada ação carrega categoria, responsável-tipo (não pessoa nominal),
// evidência esperada e prazo padrão para revisão.
model ActionTemplate {
  id                   String   @id @default(uuid()) @db.Uuid
  title                String
  category             String // Pessoas | Operação | Cultura | Cliente | Compliance | …
  description          String?
  suggestedResponsible String? // ex: "RH", "Gestor da área", "Liderança direta"
  expectedEvidence     String? // ex: "Ata da reunião", "Plano publicado no Confluence"
  defaultReviewDays    Int      @default(30)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([category])
  @@index([active])
  @@map("action_templates")
}

// Textos editáveis (copy do produto): key-value de strings/blobs longos que o
// Super Admin pode editar SEM precisar de deploy. Casos típicos: rodapé do
// Relatório Preliminar, e-mail de boas-vindas, parágrafos legais. `key` é
// estável; `version` permite rollback.
model EditableText {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique // ex: "EMAIL_WELCOME_BODY"
  category  String   @default("geral") // emails | legais | onboarding | reports …
  content   String // texto/markdown
  version   Int      @default(1)
  updatedBy String? // e-mail do super admin que editou
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("editable_texts")
}

// Conteúdo GLOBAL da Academia CRIVO (control plane). Distinto do LibraryItem
// (que é por-tenant). Super admin cura cursos/vídeos/trilhas DISPONÍVEIS para
// todos os clientes Premium. Cliente pode IMPORTAR (gera LibraryItem na sua
// biblioteca) ou apenas referenciar pelo ID.
model GlobalAcademyContent {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  kind        String // curso | video | trilha | ebook | artigo | podcast
  description String?
  url         String?
  category    String?
  tags        String[] @default([])
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([kind])
  @@map("global_academy_content")
}

// Trilha de auditoria das ações de plataforma (F2). Control plane: owner-only
// (sem RLS por tenant; crivo_app sem acesso). tenantId null = ação global de
// super admin. Append-only na prática (escrita best-effort pelo módulo Admin).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @db.Uuid // null = ação de super admin (global)
  actorId    String?
  actorEmail String?
  action     String // tenant.provision | tenant.suspend | tenant.activate | tenant.delete | admin.login
  target     String? // id/slug do alvo
  meta       Json?
  at         DateTime @default(now())

  @@index([tenantId])
  @@index([at])
  @@map("audit_log")
}

// =====================================================================
// PRODUTOS (núcleo product-driven) — TUDO nasce de um Produto. Um produto
// define preço, limites, módulos liberados, o INSTRUMENTO de diagnóstico
// (perguntas editáveis) e a configuração de IA dos líderes. Ao converter um
// lead em cliente, a empresa é provisionada A PARTIR do produto contratado.
// Control plane (owner-only): catálogo global, fora da RLS por tenant.
// Ver diretriz estrutural 2026-06 (Super Admin product-driven).
// =====================================================================
model Product {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique // pre-diagnostico-crivo, crivo-enterprise…
  name        String
  description String?
  status      ProductStatus @default(DRAFT)
  plan        Plan? // plano-base herdado pela empresa (opcional)

  // Dados gerais / comercial
  monthlyPriceCents Int     @default(0) // valor mensal (centavos)
  setupPriceCents   Int     @default(0) // valor de implantação (centavos)
  maxUsers          Int     @default(0) // 0 = ilimitado
  maxLeaders        Int     @default(0) // 0 = ilimitado
  companyType       String? // tipo de empresa atendida

  // Módulos liberados: códigos do ModuleCatalog habilitados por este produto.
  modules Json @default("[]") // string[] de moduleCode

  // Método CRIVO deste produto + saídas técnicas que ele pode gerar (Briefing §4).
  // coreModules = liberados automaticamente na contratação (CORE da Matriz).
  method           DiagnosticMethod?
  coreModules      Json              @default("[]") // string[] de moduleCode (CORE)
  supportedOutputs Json              @default("[]") // TechnicalOutput[] suportados

  // Instrumento de diagnóstico EDITÁVEL (não fixo): blocos, categorias,
  // dimensões, escalas de resposta, pesos e perguntas. Cada produto tem o seu.
  // { dimensions:[{key,label}], scales:[{key,label,options:[{value,label}]}],
  //   blocks:[{key,label}], questions:[{id,text,block,dimension,scale,weight,inverse}] }
  diagnostic Json?

  // Configuração da IA dos líderes (por produto).
  // { prompt, knowledgeBase, rules, limitations, objective, documents:[] }
  aiConfig Json?

  // Produto de captura (pré-diagnóstico): só LP/formulário/lead — SEM portal,
  // SEM app, SEM IA. Usado pelo funil comercial da CRIVO.
  isLeadCapture Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// =====================================================================
// CRM DO SUPER ADMIN — funil comercial da CRIVO. O lead nasce do Diagnóstico
// Inicial da Landing Page (ou cadastro manual) e pertence ao SUPER ADMIN, não
// a uma empresa. Control plane (owner-only). Ao fechar a venda, é convertido
// em Tenant (convertedTenantId) provisionando a empresa pelo produto.
// =====================================================================
model PlatformLead {
  id             String  @id @default(uuid()) @db.Uuid
  name           String
  company        String?
  email          String?
  phone          String?
  segment        String?
  employeesCount String? // faixa ("51-200") ou número informado
  origin         String? // lp-diagnostico | qrcode | indicacao | anuncio…
  productId      String? @db.Uuid // produto de origem (ex.: pré-diagnóstico)

  // Resultado do pré-diagnóstico (leitura preliminar — não é ICD oficial).
  diagnosticScore  Int? // 0–100 (score geral)
  diagnosticResult Json? // { score, level, byDimension, topConcern, recommendation }

  stage             PlatformLeadStage @default(NOVO)
  notes             String?
  convertedTenantId String?           @db.Uuid // tenant criado na conversão (FASE 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([createdAt])
  @@map("platform_leads")
}

// =====================================================================
// CONTRATO (Briefing §11 + Matriz §Super Admin) — o que a CRIVO configura por
// cliente SEM programação: produto, modelo, prazo, rodadas, respondentes,
// líderes, integração técnica (AEP/PGR), módulos opcionais, responsável e
// status. Control plane (owner-only). Um contrato ATIVO por empresa; histórico
// permitido. O portal libera menus a partir do produto (CORE) + opcionais.
// =====================================================================
model Contract {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid // → organizations.id (empresa-cliente)
  productId      String?        @db.Uuid // → products.id (produto contratado)
  model          ContractModel  @default(PONTUAL)
  status         ContractStatus @default(RASCUNHO)

  // Método é herdado do produto, mas pode ser sobrescrito por contrato.
  method          DiagnosticMethod?
  // Saída técnica define os documentos gerados — independente do método.
  technicalOutput TechnicalOutput   @default(SEM_INTEGRACAO)

  startDate      DateTime?
  endDate        DateTime?
  accessDays     Int? // prazo de acesso (dias) — alternativa a endDate
  rounds         Int       @default(1) // rodadas/ciclos/pulsos
  maxRespondents Int       @default(0) // 0 = ilimitado
  maxLeaders     Int       @default(0)

  // Módulos opcionais ativados além do CORE do produto (códigos do ModuleCatalog).
  optionalModules Json    @default("[]")
  responsible     String? // responsável CRIVO pelo contrato
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("contracts")
}

// =====================================================================
// CONFIGURAÇÃO DE IA (Super Admin · auditoria 2.3.1) — token OpenAI/ChatGPT
// configurável SEM código, CRIPTOGRAFADO em repouso (AES-256-GCM com chave
// derivada de AUTH_SECRET). Singleton (scope='global'). Control plane
// (owner-only): nenhum usuário comum lê o token. Prompts por produto vivem em
// Product.aiConfig; aqui ficam token, modelo, ativação e módulos habilitados.
// =====================================================================
model AiSettings {
  id       String @id @default(uuid()) @db.Uuid
  scope    String @unique @default("global")
  provider String @default("openai")
  model    String @default("gpt-4o-mini")

  // Token criptografado (nunca em claro no banco nem na API de leitura).
  apiKeyEnc  String? // ciphertext base64
  apiKeyIv   String? // IV base64
  apiKeyTag  String? // auth tag base64 (GCM)
  apiKeyHint String? // últimos 4 chars, p/ exibir mascarado

  enabled        Boolean   @default(false)
  enabledModules Json      @default("[]") // string[] de moduleCode que podem usar IA
  lastStatus     String? // ok | invalid | error | rate_limited | untested
  lastTestedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_settings")
}

// =====================================================================
// RBAC DINÂMICO (F3) — catálogo GLOBAL de permissões (módulo:ação) e papéis
// de sistema. Sem RLS por tenant (catálogo compartilhado entre todas as
// empresas); SOMENTE-LEITURA para o app — escrita só via seed/owner (rls.sql).
// Papéis customizados POR empresa e atribuição multi-papel (UserRole) entram
// na próxima fatia. Ver docs/SAAS-TRANSFORMATION.md §6.
// =====================================================================

model Permission {
  id     String           @id @default(uuid()) @db.Uuid
  code   String           @unique // "leads:view"
  module String // leads
  action String // view | create | edit | delete | export | submit
  label  String
  roles  RolePermission[]

  @@map("permissions")
}

model RoleDef {
  id       String           @id @default(uuid()) @db.Uuid
  code     String           @unique // espelha o enum Role: ADMIN, CEO, GESTOR, RH, LIDER, JURIDICO, COLABORADOR
  name     String
  isSystem Boolean          @default(true)
  perms    RolePermission[]

  @@map("role_defs")
}

model RolePermission {
  roleId String     @db.Uuid
  permId String     @db.Uuid
  role   RoleDef    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  perm   Permission @relation(fields: [permId], references: [id], onDelete: Cascade)

  @@id([roleId, permId])
  @@map("role_permissions")
}

// =====================================================================
// PLANOS + MÓDULOS (F4) — catálogo GLOBAL de módulos da plataforma e a
// ativação por empresa. ModuleCatalog é compartilhado (sem RLS por tenant,
// SOMENTE-LEITURA p/ o app, como o catálogo RBAC). TenantModule é DATA PLANE
// (RLS por tenant): o app lê os módulos da própria empresa via forTenant; a
// ESCRITA é owner-only (super admin), para uma empresa não auto-habilitar
// módulos que não contratou. Ver docs/SAAS-TRANSFORMATION.md §4.
// =====================================================================

model ModuleCatalog {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique // dashboard | icd | crm | relatorios | ...
  name      String
  category  String
  minPlan   Plan     @default(BASE) // plano mínimo p/ habilitar
  createdAt DateTime @default(now())

  @@map("module_catalog")
}

// Domínios próprios por empresa (F5). A resolução por domínio acontece ANTES
// de conhecer o tenant (pré-login), então tenant_domains é CONTROL PLANE:
// acesso só via owner (crivo_app revogado no rls.sql). organizationId liga ao
// data plane (sem relation Prisma p/ manter o desacoplamento, como Tenant).
model TenantDomain {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @db.Uuid // → organizations.id (data plane)
  domain            String    @unique // app.clientex.com | clientex.crivolegacy.com.br
  verified          Boolean   @default(false)
  primary           Boolean   @default(false)
  // Token TXT que o cliente deve publicar em _crivo.<domain> para provar posse.
  // Gerado na criação do registro (32 hex chars), nunca regenerado em prod.
  verificationToken String? // null em domínios legados pré-#55; preenchido em novos
  verifiedAt        DateTime?
  lastVerifyAttempt DateTime?
  lastVerifyError   String? // razão do último insucesso (lookup, mismatch, timeout)
  createdAt         DateTime  @default(now())

  @@index([organizationId])
  @@map("tenant_domains")
}

// White-label (F5): identidade visual por empresa. 1:1 com Organization.
// Data plane (RLS por tenant): a plataforma lê a própria via forTenant; a
// escrita é owner-only (super admin define), como tenant_modules. As cores
// sobrescrevem os tokens --crivo-* (primária = azul-profundo, acento = terra).
model TenantBranding {
  tenantId     String       @id @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl      String?
  faviconUrl   String?
  primaryColor String? // hex, sobrescreve --crivo-azul-profundo
  accentColor  String? // hex, sobrescreve --crivo-terra
  emailFrom    String?
  whatsapp     String?
  footerText   String?
  updatedAt    DateTime     @updatedAt

  @@map("tenant_branding")
}

// Biblioteca & Formação: conteúdo (materiais/cursos) por empresa. Data plane
// (RLS por tenant): a empresa vê/gere o próprio acervo. Escrita gateada por
// `library:manage` na API; leitura por `library:view`.
model LibraryItem {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  org         Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  kind        String // artigo | podcast | ebook | curso | framework
  url         String?
  createdAt   DateTime     @default(now())

  @@index([tenantId])
  @@map("library_items")
}

// Metering (F4): contadores de uso por empresa/métrica/período (YYYY-MM).
// Data plane (RLS por tenant): o app incrementa sob forTenant. Base p/ billing
// e enforcement de limites de plano (PLAN_LIMITS).
model UsageCounter {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric    String // leads | api_calls | active_users
  period    String // YYYY-MM
  value     BigInt       @default(0)
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, metric, period])
  @@index([tenantId])
  @@map("usage_counters")
}

// Quais módulos a empresa ativou. PK composta (tenant + módulo). tenantId =
// organizationId (data plane). config reservado p/ parametrização por módulo.
model TenantModule {
  tenantId   String       @db.Uuid
  org        Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleCode String
  enabled    Boolean      @default(true)
  config     Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@id([tenantId, moduleCode])
  @@index([tenantId])
  @@map("tenant_modules")
}

// =====================================================================
// TENANCY — Organization é o tenant raiz (holding). Todo registro de
// negócio carrega tenantId = organizationId e é protegido por RLS.
// =====================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(BASE)
  // Slug público do Questionário Psicossocial (Briefing §6): link anônimo sem
  // login (/q/<slug>), opcionalmente por setor via query. Único entre empresas.
  psychosocialSlug String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies        Company[]
  units            Unit[]
  teams            Team[]
  users            User[]
  cycles           AssessmentCycle[]
  assessments      Assessment[]
  responses        Response[]
  icdScores        IcdScore[]
  leads            Lead[]
  modules          TenantModule[]
  usage            UsageCounter[]
  branding         TenantBranding?
  library          LibraryItem[]
  actionPlans      ActionPlan[]
  actionItems      ActionItem[]
  evidences        Evidence[]
  selfAssessments  SelfAssessment[]
  essentialRecords EssentialRecord[]
  pareceres        Parecer[]
  psychosocialResponses PsychosocialResponse[]

  // Anexo ICD do Líder v1 — Registro de Decisão (task #45).
  decisionCategories  DecisionCategory[]
  decisionIcdScores   DecisionIcdScore[]
  icdCycles           IcdCycle[]
  leaderQuarterlyIcd  LeaderQuarterlyIcd[]
  companyQuarterlyIcd CompanyQuarterlyIcd[]
  affectedAudiences   AffectedAudience[]
  decisions           Decision[]
  sustentationActions SustentationAction[]
  PocketSession       PocketSession[]
  PocketReflection    PocketReflection[]
  PocketAiSummary     PocketAiSummary[]
  TenantRole          TenantRole[]

  @@map("organizations")
}

model Company {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  cnpj         String?
  createdAt    DateTime     @default(now())

  units Unit[]

  @@index([tenantId])
  @@map("companies")
}

model Unit {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String       @db.Uuid
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  region    String?
  createdAt DateTime     @default(now())

  teams Team[]

  @@index([tenantId])
  @@index([companyId])
  @@map("units")
}

model Team {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId    String       @db.Uuid
  unit      Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime     @default(now())

  members TeamMember[]

  @@index([tenantId])
  @@index([unitId])
  @@map("teams")
}

// =====================================================================
// IAM
// =====================================================================

model User {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @db.Uuid
  org             Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String
  name            String
  passwordHash    String
  role            Role         @default(COLABORADOR)
  active          Boolean      @default(true)
  // Aceite de termos/LGPD no 1º acesso (Briefing · Matriz §Confidencialidade).
  termsAcceptedAt DateTime?
  termsVersion    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  memberships              TeamMember[]
  assessments              Assessment[]         @relation("LeaderAssessments")
  icdScores                IcdScore[]           @relation("LeaderScores")
  // Anexo ICD do Líder v1 — decisões registradas pelo líder (task #45).
  decisions                Decision[]           @relation("LeaderDecisions")
  decisionIcdScoresMine    DecisionIcdScore[]   @relation("LeaderDecisionIcdScores")
  leaderQuarterlyIcdScores LeaderQuarterlyIcd[] @relation("LeaderQuarterlyIcdScores")
  pocketSessions           PocketSession[]      @relation("LeaderPocketSessions")
  userRoles                UserRole[] // #68 — multi-papel dinâmico

  // E-mail único POR tenant (mesmo e-mail pode existir em orgs diferentes)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model TeamMember {
  teamId   String  @db.Uuid
  userId   String  @db.Uuid
  tenantId String  @db.Uuid
  isLeader Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([tenantId])
  @@map("team_members")
}

// =====================================================================
// AVALIAÇÕES & ICD (Fase F1)
// =====================================================================

model AssessmentCycle {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  org            Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  description    String? // contexto/instrução opcional da campanha
  sector         String? // setor/área alvo (RH, Comercial, Operações…); null = toda a empresa
  // Slug público para link de convite (Anexo Portal §7): respondentes acessam
  // /p/c/<slug> sem login. Único por tenant para evitar colisão de leituras.
  publicSlug     String?      @unique
  startsAt       DateTime? // janela opcional
  endsAt         DateTime?
  reminderAt     DateTime? // quando o sistema deve enviar lembrete (job futuro)
  reminderSentAt DateTime? // idempotência: marca quando enviou
  status         CycleStatus  @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assessments Assessment[]

  @@index([tenantId])
  @@index([sector])
  @@map("assessment_cycles")
}

model Assessment {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid
  org       Organization     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycleId   String?          @db.Uuid
  cycle     AssessmentCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  leaderId  String           @db.Uuid
  leader    User             @relation("LeaderAssessments", fields: [leaderId], references: [id], onDelete: Cascade)
  type      AssessmentType   @default(ICD)
  createdAt DateTime         @default(now())

  response Response?
  score    IcdScore?

  @@index([tenantId])
  @@index([leaderId])
  @@map("assessments")
}

model Response {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  org          Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentId String       @unique @db.Uuid
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers      Json // [{ questionId, value }]
  submittedAt  DateTime     @default(now())

  @@index([tenantId])
  @@map("responses")
}

// Resposta ao Questionário Psicossocial Organizacional (Briefing §6 — diagnóstico
// AMPLO por colaborador). ANÔNIMA por design (§11/§14): NÃO há vínculo com User.
// Guarda só tenant + setor + respostas + score agregável. Confidencialidade é
// garantida na agregação (supressão < 5 respondentes por recorte).
model PsychosocialResponse {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  org         Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sector      String? // setor/área (RH, Comercial…); null = não informado
  answers     Json // [{ questionId, value }] — 12 itens, escala 1–5
  score       Int // 0–100 (proteção geral; maior = menor risco)
  level       String // BAIXO | MODERADO | ALTO | CRITICO
  byDimension Json // { demandas, controle, apoio, reconhecimento, clareza, relacoes } 0–100
  submittedAt DateTime     @default(now())

  @@index([tenantId])
  @@index([sector])
  @@map("psychosocial_responses")
}

// =====================================================================
// COMERCIAL — Pipeline de leads (alimentado pela LP e por cadastro manual)
// =====================================================================

model Lead {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  email     String?
  whatsapp  String?
  segment   String?
  origin    String? // lp-diagnostico, lp-ebook-nr1, manual…
  stage     LeadStage    @default(NOVO)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, stage])
  @@map("leads")
}

model IcdScore {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @db.Uuid
  org             Organization    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentId    String          @unique @db.Uuid
  assessment      Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  leaderId        String          @db.Uuid
  leader          User            @relation("LeaderScores", fields: [leaderId], references: [id], onDelete: Cascade)
  score           Int // 0–100
  dimensions      Json // { clareza, pressao, confianca, influencia, risco } (0–100, normalizado p/ coerência)
  dominantPattern DominantPattern
  computedAt      DateTime        @default(now())

  @@index([tenantId])
  @@index([leaderId])
  @@map("icd_scores")
}

// =====================================================================
// PLANO DE AÇÃO + EVIDÊNCIAS (Briefing §8/§9 + Matriz §Plano de Ação) — CORE de
// todo diagnóstico. Data plane (RLS por tenant). O plano final só vira documento
// após validação pela empresa/responsável (validatedAt). Ações podem ser
// sugeridas (IA/biblioteca), mas a validação é humana.
// =====================================================================
model ActionPlan {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  org         Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  source      String? // autoavaliação | escuta | questionário | observação | parecer
  validatedAt DateTime? // sem validação = minuta; com validação = documento final
  validatedBy String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items ActionItem[]

  @@index([tenantId])
  @@map("action_plans")
}

model ActionItem {
  id               String       @id @default(uuid()) @db.Uuid
  tenantId         String       @db.Uuid
  org              Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String       @db.Uuid
  plan             ActionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  point            String // ponto identificado (= fator psicossocial, para o inventário §6/§15)
  origin           String? // origem do ponto (autoavaliação/escuta/questionário/observação/parecer)
  action           String // ação proposta (= medida de controle no inventário)
  responsible      String? // responsável (empresa)
  dueDate          DateTime?
  status           ActionStatus @default(SUGERIDA)
  expectedEvidence String? // evidência esperada
  reviewDate       DateTime? // data de revisão de efetividade
  // Inventário de fatores psicossociais (apoio ao PGR §6/§15): dimensões que
  // estruturam o ponto como fator de risco. exposedGroup = grupos expostos;
  // riskLevel = classificação (BAIXO|MEDIO|ALTO|CRITICO).
  exposedGroup     String?
  riskLevel        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  evidences Evidence[]

  @@index([tenantId])
  @@index([planId])
  @@map("action_items")
}

model Evidence {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId    String?      @db.Uuid // vínculo opcional com a ação
  item      ActionItem?  @relation(fields: [itemId], references: [id], onDelete: SetNull)
  kind      String // ata | reuniao | print | foto | documento | comunicado | lista | treinamento | link
  title     String
  url       String? // link/referência (quando a evidência é um link)
  note      String?
  // Metadados do upload (quando a evidência é um arquivo, não um link). Os BYTES
  // ficam em EvidenceFile (tabela separada), p/ a linha de evidência permanecer
  // leve em listagens. fileName preenchido ⇒ há arquivo.
  fileName  String?
  fileMime  String?
  fileSize  Int? // tamanho em bytes
  file      EvidenceFile?
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@index([itemId])
  @@map("evidences")
}

// Bytes do arquivo de uma evidência (1:1 com Evidence). Tabela separada para que
// os bytes NUNCA tragem em listagens de evidência — só são lidos no download.
// Data plane (RLS por tenant). Documentos pequenos (atas, prints, PDFs).
model EvidenceFile {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  evidenceId String   @unique @db.Uuid
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  data       Bytes
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@map("evidence_files")
}

// =====================================================================
// PARECER CONSULTIVO CRIVO (Briefing §6) — camada HUMANA do diagnóstico. O
// consultor consolida os indicadores e redige sinais/hipóteses/prioridades/
// recomendações. Vira documento (PDF) só após publicação (publishedAt). Data
// plane (RLS por tenant). Não é gerado por IA nem promete conformidade automática.
// =====================================================================
model Parecer {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @db.Uuid
  org             Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  status          String       @default("RASCUNHO") // RASCUNHO | PUBLICADO
  context         String? // contexto/leitura da empresa
  signals         String? // sinais observados nos indicadores
  hypotheses      String? // hipóteses de trabalho
  priorities      String? // prioridades
  recommendations String? // recomendações
  author          String? // consultor responsável
  devolutivaAt    DateTime? // devolutiva agendada
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([tenantId])
  @@map("pareceres")
}

// =====================================================================
// DIAGNÓSTICO ESSENCIAL (Briefing §5) — jornada simples para empresas pequenas:
// autoavaliação guiada + registro de escuta/observação → pontos de atenção que
// alimentam o Plano de Ação e o dossiê AEP/AEP+PGR. Data plane (RLS por tenant).
// =====================================================================
model SelfAssessment {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers   Json // [{ questionId, value }]
  score     Int // 0–100 (maturidade)
  result    Json // { score, level, byDimension, topAttention }
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@map("self_assessments")
}

model EssentialRecord {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @db.Uuid
  org          Organization        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind         EssentialRecordKind
  title        String
  recordDate   DateTime?
  participants String? // quem participou da escuta / contexto da observação
  notes        String?
  points       String? // pontos de atenção identificados
  createdAt    DateTime            @default(now())

  @@index([tenantId])
  @@map("essential_records")
}

// =====================================================================
// REGISTRO DE DECISÃO — modelos (Anexo Técnico ICD do Líder v1, §5).
//
// Coexiste com Assessment/Response/IcdScore (modelo legado 4 Rs) durante
// a transição. Os scores ICD por decisão e o cálculo trimestral entram
// nas próximas migrations (tasks #46 e #47).
// =====================================================================

// §5.1 — Categorias de decisão. Lista padrão sugerida pelo Anexo:
// Pessoas, Operação, Cliente, Estratégia, Financeiro, Cultura, Processo,
// Risco/Compliance, Outro. Customizável por empresa via Super Admin.
model DecisionCategory {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String // identificador estável (ex.: "pessoas", "operacao")
  isDefault Boolean      @default(false) // seedada como sugestão CRIVO
  active    Boolean      @default(true)
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  decisions Decision[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("decision_categories")
}

// §5.1 — Públicos / áreas impactados pela decisão. Multi-seleção por decisão.
// Cadastrados por empresa no Super Admin (áreas, unidades, cargos, públicos).
model AffectedAudience {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  org       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  active    Boolean      @default(true)
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  decisions DecisionAudience[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("affected_audiences")
}

// §5.1 — Decisão real registrada pela liderança. Base operacional do ICD
// e do histórico de prática decisória. Os campos abaixo cobrem o registro
// visível ao líder; respostas P1-P8 e score por eixo vivem em modelos
// próprios (próxima migration — task #46).
model Decision {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @db.Uuid
  org      Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaderId String       @db.Uuid
  leader   User         @relation("LeaderDecisions", fields: [leaderId], references: [id], onDelete: Cascade)

  title          String
  description    String?
  categoryId     String?                 @db.Uuid
  category       DecisionCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  impact         DecisionImpact
  type           DecisionType
  pocketUse      DecisionPocketUse       @default(NAO_UTILIZADO)
  pressureFactor DecisionPressureFactor?
  revisionPeriod DecisionRevisionPeriod  @default(SEM_REVISAO)
  status         DecisionStatus          @default(EM_REGISTRO)

  // Momento em que a decisão foi tomada (não o registro). Anexo §5.1.
  decidedAt DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete (#77): líderes podem "remover" decisões EM_REGISTRO/REGISTRADA,
  // mas o registro fica para auditoria (§17). NULL = ativo; timestamp = removido.
  deletedAt DateTime?

  audiences          DecisionAudience[]
  sustentationAction SustentationAction?
  icdScore           DecisionIcdScore?
  pocketSessions     PocketSession[] // vínculo opcional (§8)

  @@index([tenantId])
  @@index([leaderId])
  @@index([decidedAt])
  @@index([deletedAt])
  @@map("decisions")
}

// §5.1 — M:N entre Decision e AffectedAudience. Permite que uma decisão
// afete múltiplos públicos simultaneamente (RH, Comercial, Operações...).
model DecisionAudience {
  decisionId String           @db.Uuid
  decision   Decision         @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  audienceId String           @db.Uuid
  audience   AffectedAudience @relation(fields: [audienceId], references: [id], onDelete: Cascade)

  @@id([decisionId, audienceId])
  @@index([audienceId])
  @@map("decision_audiences")
}

// §5.2 — Ação concreta para sustentar/implementar/comunicar a decisão.
// 1:1 obrigatória com a decisão. Reusa ActionStatus existente.
model SustentationAction {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @db.Uuid
  org        Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decisionId String       @unique @db.Uuid
  decision   Decision     @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  action         String // O que será feito (obrigatório, §5.2)
  responsible    String // Pessoa, líder, área ou equipe (obrigatório)
  deadline       DateTime // Prazo limite ou data da 1ª revisão (obrigatório)
  expectedResult String? // Qual efeito a ação pretende gerar (opcional)
  evidenceUrl    String? // Ata, comunicado, plano, print, indicador… (opcional)
  status         ActionStatus @default(SUGERIDA)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([decisionId])
  @@map("sustentation_actions")
}

// Anexo ICD §6–§9 — ICD de UMA decisão (4 eixos × 2 perguntas). 1:1 com Decision.
// `axes` é um Json {clareza, criterio, alinhamento, sustentacao} cada um 0–100
// (média dos 2 scores das perguntas do eixo). `score` é a média dos 4 eixos.
// `answers` armazena as 8 respostas brutas (id P1-P8 + value 1-5) para auditoria.
// `weight` espelha DECISION_IMPACT_WEIGHT do impact da decisão na hora do registro
// (BAIXO=0 → não entra no fechamento trimestral; MEDIO=1; ALTO=2).
model DecisionIcdScore {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @db.Uuid
  org        Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decisionId String       @unique @db.Uuid
  decision   Decision     @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  leaderId   String       @db.Uuid
  leader     User         @relation("LeaderDecisionIcdScores", fields: [leaderId], references: [id], onDelete: Cascade)
  // Ciclo trimestral em que a avaliação caiu (definido pelo decidedAt da decisão).
  // null = avaliada fora de qualquer ciclo aberto (legado/seed). §9.4 conta só
  // as que têm cycleId no fechamento.
  cycleId    String?      @db.Uuid
  cycle      IcdCycle?    @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  score      Int // 0–100, média dos 4 eixos (§9.2)
  axes       Json // { clareza, criterio, alinhamento, sustentacao } cada 0–100
  answers    Json // [{ id: "P1"|...|"P8", value: 1..5 }]
  weight     Int // 0|1|2 derivado do impact da decisão (§9.3)
  computedAt DateTime @default(now())

  @@index([tenantId])
  @@index([leaderId])
  @@index([cycleId])
  @@index([computedAt])
  @@map("decision_icd_scores")
}

// Anexo ICD §9.4 e §9.6 — janela trimestral oficial do ICD. Um ciclo agrupa
// todas as avaliações de decisões cuja `decidedAt` cai dentro do intervalo
// [startsAt, endsAt]. OPEN = parcial; CLOSED = oficial congelado. Único por
// tenant: só pode existir 1 OPEN por vez (lógica garantida no service).
model IcdCycle {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @db.Uuid
  org       Organization   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String // ex: "2026-Q3" (label gerado, editável)
  quarter   Int // 1..4
  year      Int
  startsAt  DateTime
  endsAt    DateTime
  status    IcdCycleStatus @default(OPEN)
  closedAt  DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  scores        DecisionIcdScore[]
  leaderResults LeaderQuarterlyIcd[]
  companyResult CompanyQuarterlyIcd?

  @@unique([tenantId, year, quarter])
  @@index([tenantId])
  @@index([status])
  @@map("icd_cycles")
}

// Anexo ICD §9.4 — ICD trimestral ponderado de um líder. Gerado no fechamento
// do ciclo. Inclui só decisões MÉDIO/ALTO impacto avaliadas pelo ICD dentro do
// ciclo (peso > 0). Líderes com 0 decisões elegíveis NÃO geram registro
// (ficam fora do §9.5 média da empresa).
model LeaderQuarterlyIcd {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @db.Uuid
  org      Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycleId  String       @db.Uuid
  cycle    IcdCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  leaderId String       @db.Uuid
  leader   User         @relation("LeaderQuarterlyIcdScores", fields: [leaderId], references: [id], onDelete: Cascade)

  score         Int // 0–100, média ponderada das decisões elegíveis
  decisionCount Int // quantas decisões MÉDIO/ALTO elegíveis entraram
  totalWeight   Int // soma dos pesos (peso médio + peso alto)
  axesAverage   Json // { clareza, criterio, alinhamento, sustentacao } médias ponderadas
  computedAt    DateTime @default(now())

  @@unique([cycleId, leaderId]) // um resultado por líder por ciclo
  @@index([tenantId])
  @@index([leaderId])
  @@map("leader_quarterly_icd")
}

// Anexo ICD §9.5 — ICD oficial da empresa no ciclo. Média dos ICDs trimestrais
// dos líderes elegíveis (>= 1 decisão MÉDIO/ALTO avaliada). NÃO é média direta
// das decisões. §11: só calculado se >= 5 líderes elegíveis (regra de
// supressão); abaixo disso, score fica null e `suppressed=true`.
model CompanyQuarterlyIcd {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @db.Uuid
  org      Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycleId  String       @unique @db.Uuid // 1:1 com ciclo
  cycle    IcdCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  score           Int? // null se suppressed (< 5 líderes elegíveis)
  eligibleLeaders Int // quantos líderes elegíveis no ciclo
  suppressed      Boolean  @default(false) // §11: recorte < 5
  distribution    Json // { critica, desenvolvimento, funcional, consistente, avancada, elevada } counts
  axesAverage     Json // médias agregadas dos 4 eixos (apenas se !suppressed)
  computedAt      DateTime @default(now())

  @@index([tenantId])
  @@map("company_quarterly_icd")
}

// Anexo Pocket §5/§12 — sessão do Pocket CRIVO. Iniciada quando o líder abre
// o módulo no app. Contém metadados de uso (contexto opcional, momento) e
// pode ser vinculada a uma Decisão existente (§8). Histórico individual (§13).
model PocketSession {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @db.Uuid
  org      Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaderId String       @db.Uuid
  leader   User         @relation("LeaderPocketSessions", fields: [leaderId], references: [id], onDelete: Cascade)

  context          String? // texto curto opcional (§7) — não é obrigatório
  momentOfUse      PocketMomentOfUse   @default(AVULSO)
  decisionId       String?             @db.Uuid // vínculo opcional §8
  decision         Decision?           @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  status           PocketSessionStatus @default(EM_ANDAMENTO)
  questionsVersion String              @default("v1") // versão das perguntas (§12)
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  reflections PocketReflection[]
  aiSummary   PocketAiSummary?

  @@index([tenantId])
  @@index([leaderId])
  @@index([decisionId])
  @@map("pocket_sessions")
}

// Anexo Pocket §7/§12 — reflexão a uma das 10 perguntas oficiais (C1-O2).
// Resposta é opcional (texto livre curto) e tags são opcionais. Cada pergunta
// pode aparecer no máximo 1 vez por sessão (gerenciado no service).
model PocketReflection {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  org          Organization  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId    String        @db.Uuid
  session      PocketSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionCode String // "C1" .. "O2"
  text         String? // resposta reflexiva opcional
  tags         String[] // tags opcionais (sinalização de estado, §7)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([sessionId, questionCode]) // 1 reflexão por pergunta por sessão
  @@index([tenantId])
  @@map("pocket_reflections")
}

// Anexo Pocket §7/§10 — síntese gerada pela Mentoria IA quando ativada.
// 1:1 com a sessão. Inclui versão do modelo/prompt para auditoria (§12).
model PocketAiSummary {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  org            Organization  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId      String        @unique @db.Uuid
  session        PocketSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  synthesis      String // resumo da reflexão do líder
  recommendation String? // cuidado/atenção sugerida (Anexo §10)
  nextStep       String? // próximo passo sugerido (Anexo §10)
  modelVersion   String // ex: "claude-opus-4-7-2026-06"
  createdAt      DateTime      @default(now())

  @@index([tenantId])
  @@map("pocket_ai_summaries")
}
